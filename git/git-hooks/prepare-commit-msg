#!/bin/sh

FILE="$1"
MESSAGE=$(cat "$FILE")

# Extract ticket number from branch (e.g., feature/12345 or fix/12345 → 12345)
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
BRANCH_SUFFIX=${BRANCH_NAME#*/}
TICKET=${BRANCH_SUFFIX%%[!0-9]*}

# Only add if we extracted numeric digits
if [ -z "$TICKET" ]; then
    echo "No numeric ticket found in branch '$BRANCH_NAME', not adding ref to ticket"
    exit 0
fi

# Check if a line exactly matches "#<ticket>"
echo "$MESSAGE" | grep -qx "#$TICKET" && exit 0

# Append the ticket reference
printf "%s\n\n#%s\n" "$MESSAGE" "$TICKET" > "$FILE"
